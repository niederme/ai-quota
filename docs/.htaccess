RewriteEngine On

# Consolidate every public URL onto the canonical HTTPS host.
RewriteCond %{HTTP_HOST} !^aiquota\.app$ [NC,OR]
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://aiquota.app%{REQUEST_URI} [R=301,L,NE]

# Tell browsers to keep using HTTPS after the first secure response.
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
